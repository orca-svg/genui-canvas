{
  "name": "@genui-canvas/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "demo:replay": "tsx src/demo/replay.ts",
    "demo:replay:live": "tsx src/demo/replay.ts --live"
  },
  "dependencies": {
    "@genui-canvas/contracts": "workspace:*",
    "@google/genai": "^2.10.0",
    "@hono/node-server": "^2.0.8",
    "@mcp-gen-ui/mcp-server": "0.2.0",
    "@mcp-gen-ui/schema": "0.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.28",
    "tsx": "^4.19.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
