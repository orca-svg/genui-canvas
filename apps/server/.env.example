# BYOK — bring your own LLM key. Nothing here is committed with a real value.
# Zero-config default (no key): the rule-based provider composes deterministically.

# Recommended free option:
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your-own-free-key   # https://aistudio.google.com/apikey
# GEMINI_MODEL=gemini-2.5-flash

# PORT=8787
# GENUI_TRACE_DIR=./data/sessions
