{
  "name": "genui-canvas",
  "version": "0.0.0",
  "private": true,
  "description": "Interaction-driven generative UI environment for the mcp-gen-ui-gateway public-benefit MCP server.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r --if-present lint",
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "demo:replay": "pnpm --filter @genui-canvas/server demo:replay"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
